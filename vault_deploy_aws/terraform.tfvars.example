# vault_deploy — example variable values
# Copy to terraform.tfvars and fill in your values before running terraform apply.

cluster_name = "cisa-vault-poc"

vault_version = "1.18.3-ent"

# vault_license = "02K..." # paste your Vault Enterprise license string here

vpc_id    = "vpc-0123456789abcdef0"
subnet_id = "subnet-0123456789abcdef0"

instance_type       = "m5.medium"
root_volume_size_gb = 50

# Lock down to your corporate egress IP instead of leaving open
vault_ingress_cidr_blocks = ["0.0.0.0/0"]

# SSH is disabled by default — use SSM Session Manager to connect
ssh_ingress_cidr_blocks = []

ssm_path_prefix              = "/vault"
kms_key_deletion_window_days = 30

tags = {
  Environment = "poc"
  Owner       = "platform-team"
}
