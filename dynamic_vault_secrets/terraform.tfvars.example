# dynamic_vault_secrets — example variable values

vault_addr  = "https://1.2.3.4:8200"
vault_token = "hvs.XXXXXXXXXXXXXXXXXXXXXXXX"  # bootstrap root token; rotate after first apply

# vault_ca_cert_file = "/path/to/vault-ca.pem"  # required for self-signed Vault TLS

vault_namespace = ""

tfe_hostname     = "tfe.example.com"
tfe_organization = "my-org"
tfe_project      = "*"
tfe_workspace    = "*"

jwt_backend_path           = "jwt-aws-provider"
vault_role_name            = "tfe-vault-backed-aws"
vault_policy_name          = "tfe-vault-backed-aws-policy"
workload_identity_audience = "vault.workload.identity"
token_ttl_seconds          = 1200

aws_secrets_backend_path   = "aws"
aws_secrets_backend_region = "us-east-1"
aws_secrets_role_name      = "tfe-dynamic-aws-role"

# IAM credentials Vault uses to call STS. Set these to the IAM user Vault
# authenticates as. If Vault runs on EC2 in the same AWS account you can omit
# these and set vault_iam_user_arn to the instance role ARN instead.
vault_aws_access_key_id     = ""
vault_aws_secret_access_key = ""

# ARN of the IAM principal above (user or role) — granted sts:AssumeRole on the target role.
vault_iam_user_arn = "arn:aws:iam::123456789012:user/vault"

default_sts_ttl_seconds = 3600
max_sts_ttl_seconds     = 43200

target_iam_role_name = "vault-dynamic-creds-target"

# Custom IAM policy for the target role (optional — defaults to read-only demo)
# target_iam_policy_json = <<-EOT
#   {
#     "Version": "2012-10-17",
#     "Statement": [{"Effect": "Allow", "Action": ["ec2:*"], "Resource": "*"}]
#   }
# EOT

tfe_workspace_id = "" # e.g. "ws-XXXXXXXXXXXXXXXX"
tfe_token        = "" # TFE org or team token with workspace-write permissions
# vault_ca_cert_b64     = "LS0tLS1CRUdJTi..."
