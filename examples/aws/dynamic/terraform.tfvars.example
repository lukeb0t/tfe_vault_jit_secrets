region         = "us-east-1"
aws_region     = "us-east-1"

# From infra/ outputs:
vault_addr = "https://1.2.3.4:8200"

# Option A (recommended): pass direct values.
vault_root_token  = "" # actual root token value
vault_ca_cert_b64 = "" # actual base64 TLS cert value

# Option B: fetch from SSM at plan/apply time (used only when the direct value is empty).
vault_root_token_ssm_path  = "" # e.g. /vault/jit-demo/root_token
vault_ca_cert_b64_ssm_path = "" # e.g. /vault/jit-demo/tls_cert_b64

# IAM principal Vault authenticates as (role or user ARN).
vault_iam_principal_arn = "" # preferred
vault_iam_role_arn      = "" # legacy alias (backward compatibility)

# Optional static AWS credentials for Vault AWS secrets engine root config.
# Use these when Vault is not using an EC2 instance profile for AWS auth.
vault_aws_access_key_id     = ""
vault_aws_secret_access_key = ""

tfe_hostname   = "1.2.3.4.nip.io"
tfe_org_token  = ""  # retrieve: aws ssm get-parameter --name /tfe/jit-demo-tfe/org-token --with-decryption --query Parameter.Value --output text
tfe_org_name   = "hashicorp-demo"
